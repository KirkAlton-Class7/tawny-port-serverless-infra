# Tawny Port REST API deployment values.
# Copy this file to .env, update the values in groups, then source it before running dependent commands.

# Core AWS values
export AWS_REGION="us-east-1"
export AWS_ACCOUNT_ID=""
export PROJECT_SLUG="tawny-port"
export API_NAME="tawny-port-rest"
export API_STAGE="prod"
export SESSION_TABLE="tawny-port-sessions"

# Auth0 values for Cellar routes
export AUTH0_ISSUER="https://<AUTH0_TENANT>.<AUTH0_REGION>.auth0.com/"
export AUTH0_AUDIENCE="<AUTH0_AUDIENCE>"
export AUTH0_JWKS_URI="https://<AUTH0_TENANT>.<AUTH0_REGION>.auth0.com/.well-known/jwks.json"
export AUTH0_TOKEN="<AUTH0_ACCESS_TOKEN>"

# Cognito values for browser login
export USER_POOL_NAME="tawny-port-sippers"
export COGNITO_APP_CLIENT_NAME="port-connoisseur"
export COGNITO_DOMAIN_PREFIX="<COGNITO_DOMAIN_PREFIX>"
export COGNITO_DOMAIN="${COGNITO_DOMAIN_PREFIX}.auth.${AWS_REGION}.amazoncognito.com"
export COGNITO_USER_POOL_ID=""
export COGNITO_APP_CLIENT_ID=""
export COGNITO_CLIENT_SECRET=""

# API Gateway outputs
export REST_API_ID=""
export ROOT_RESOURCE_ID=""
export API_ENDPOINT=""
export API_HOST=""
export AUTH0_AUTHORIZER_ID=""

# Lambda role names
export AUTH0_AUTHORIZER_ROLE="tawny-port-rest-auth0-authorizer-role"
export PYTHON_CASK_ROLE="tawny-port-rest-python-cask-role"
export NODE_BARREL_ROLE="tawny-port-rest-node-barrel-role"
export SOMMELIER_ROLE="tawny-port-rest-sommelier-role"
export AUTH_CALLBACK_ROLE="tawny-port-rest-auth-callback-role"
export COGNITO_LOGOUT_ROLE="tawny-port-rest-cognito-logout-role"
export PYTHON_SIPPER_ROLE="tawny-port-rest-python-sipper-role"
export NODE_SIPPER_ROLE="tawny-port-rest-node-sipper-role"

# Lambda function names
export AUTH0_AUTHORIZER_FUNCTION="auth0-jwt-authorizer"
export PYTHON_CASK_FUNCTION="python-cask"
export NODE_BARREL_FUNCTION="node-barrel"
export SOMMELIER_FUNCTION="sommelier"
export AUTH_CALLBACK_FUNCTION="auth-callback"
export COGNITO_LOGOUT_FUNCTION="cognito-logout"
export PYTHON_SIPPER_FUNCTION="python-sipper"
export NODE_SIPPER_FUNCTION="node-sipper"

# Derived values populated after API creation
export CALLBACK_REDIRECT_URI=""
export POST_LOGOUT_REDIRECT_URI=""
export BASE_CHALICE_URL=""
